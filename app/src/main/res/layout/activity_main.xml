<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gk_bg_term"
    android:fitsSystemWindows="true">

    <!-- 状态行:厂商 / 模型 / root 状态 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/gk_bg_deepest"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:textColor="@color/gk_fg_sub"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="Grok Build" />

        <TextView
            android:id="@+id/rootStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:textColor="@color/gk_yellow"
            android:text="@string/status_root_unknown" />

        <TextView
            android:id="@+id/menuButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="18sp"
            android:paddingHorizontal="8dp"
            android:textColor="@color/gk_fg_main"
            android:text="⋮" />
    </LinearLayout>

    <!-- 终端(运行真实 grok TUI) -->
    <com.termux.view.TerminalView
        android:id="@+id/terminalView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:background="@color/gk_bg_term" />

    <!-- TUI 触屏辅助键 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/gk_bg_dark"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/extraKeys"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp" />
    </HorizontalScrollView>
</LinearLayout>
