<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gk_bg_term"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="monospace"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/gk_blue"
            android:text="›_ Grok Build" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="28dp"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:textColor="@color/gk_fg_muted"
            android:text="@string/launcher_subtitle" />

        <!-- 终端模式卡片 -->
        <LinearLayout
            android:id="@+id/cardTerminal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/gk_bg_main"
            android:padding="18dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFamily="monospace" android:textSize="18sp" android:textStyle="bold"
                android:textColor="@color/gk_green" android:text="@string/mode_terminal" />
            <TextView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="monospace" android:textSize="12sp"
                android:textColor="@color/gk_fg_sub" android:text="@string/mode_terminal_desc" />
        </LinearLayout>

        <!-- 图形模式卡片 -->
        <LinearLayout
            android:id="@+id/cardGui"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/gk_bg_main"
            android:padding="18dp"
            android:layout_marginBottom="20dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFamily="monospace" android:textSize="18sp" android:textStyle="bold"
                android:textColor="@color/gk_magenta" android:text="@string/mode_gui" />
            <TextView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="monospace" android:textSize="12sp"
                android:textColor="@color/gk_fg_sub" android:text="@string/mode_gui_desc" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/rememberCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/gk_blue"
            android:textColor="@color/gk_fg_muted"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:text="@string/launcher_remember" />
    </LinearLayout>
</ScrollView>
