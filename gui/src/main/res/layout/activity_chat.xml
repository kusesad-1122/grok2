<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gk_bg_term"
    android:fitsSystemWindows="true">

    <!-- 状态行:厂商 · 模型 · root -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/gk_bg_deepest"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:textColor="@color/gk_fg_sub"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="Grok Build" />

        <TextView
            android:id="@+id/rootStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingHorizontal="8dp"
            android:textColor="@color/gk_yellow"
            android:text="@string/status_root_unknown" />

        <TextView
            android:id="@+id/menuButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="18sp"
            android:paddingHorizontal="8dp"
            android:textColor="@color/gk_fg_main"
            android:text="⋮" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingVertical="6dp"
        android:scrollbars="vertical" />

    <!-- grok 正在思考 -->
    <TextView
        android:id="@+id/thinkingBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="@color/gk_bg_dark"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:textColor="@color/gk_orange"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:text="@string/thinking" />

    <!-- 命令面板输入 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/gk_bg_dark"
        android:padding="6dp"
        android:gravity="bottom">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="16sp"
            android:textColor="@color/gk_blue"
            android:paddingHorizontal="4dp"
            android:paddingTop="10dp"
            android:text="›" />

        <EditText
            android:id="@+id/input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@color/gk_bg_deepest"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:textColor="@color/gk_fg_main"
            android:textColorHint="@color/gk_fg_muted"
            android:hint="@string/hint_input"
            android:gravity="top"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="1"
            android:maxLines="6"
            android:padding="8dp"
            android:importantForAutofill="no" />

        <Button
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="@string/send"
            android:textColor="@color/gk_bg_term"
            android:backgroundTint="@color/gk_blue" />
    </LinearLayout>
</LinearLayout>
