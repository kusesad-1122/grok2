<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- grok 神似的深色终端主题 -->
    <style name="Theme.GrokGui" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/gk_blue</item>
        <item name="colorOnPrimary">@color/gk_bg_term</item>
        <item name="colorSecondary">@color/gk_magenta</item>
        <item name="android:colorBackground">@color/gk_bg_term</item>
        <item name="colorSurface">@color/gk_bg_main</item>
        <item name="colorOnSurface">@color/gk_fg_main</item>
        <item name="android:statusBarColor">@color/gk_bg_deepest</item>
        <item name="android:navigationBarColor">@color/gk_bg_deepest</item>
        <item name="android:windowBackground">@color/gk_bg_term</item>
        <item name="android:textColorPrimary">@color/gk_fg_main</item>
        <item name="android:textColorSecondary">@color/gk_fg_sub</item>
        <item name="android:textColorHint">@color/gk_fg_muted</item>
    </style>

    <style name="Theme.GrokGui.Settings" parent="Theme.Material3.Dark">
        <item name="colorPrimary">@color/gk_blue</item>
        <item name="colorOnPrimary">@color/gk_bg_term</item>
        <item name="android:colorBackground">@color/gk_bg_main</item>
        <item name="colorSurface">@color/gk_bg_dark</item>
        <item name="colorOnSurface">@color/gk_fg_main</item>
        <item name="android:statusBarColor">@color/gk_bg_deepest</item>
        <item name="android:textColorHint">@color/gk_fg_muted</item>
    </style>

    <style name="GkLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/gk_cyan</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginBottom">4dp</item>
    </style>

    <style name="GkInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/gk_fg_main</item>
        <item name="android:textColorHint">@color/gk_fg_muted</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">10dp</item>
        <item name="android:background">@color/gk_bg_dark</item>
    </style>
</resources>
